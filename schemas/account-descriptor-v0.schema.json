{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nsealr.dev/schemas/account-descriptor-v0.schema.json",
  "title": "nSealr Account Descriptor v0",
  "type": "object",
  "required": [
    "format",
    "account_id",
    "label",
    "public_key",
    "signer_route",
    "recovery",
    "capabilities",
    "policy_profile_id"
  ],
  "properties": {
    "format": { "const": "nsealr-account-descriptor-v0" },
    "account_id": { "type": "string", "pattern": "^[A-Za-z0-9._:-]{1,128}$" },
    "label": { "type": "string", "minLength": 1 },
    "public_key": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "signer_route": {
      "type": "object",
      "required": ["type", "transport", "custody", "trusted_review", "policy_support"],
      "properties": {
        "type": {
          "enum": [
            "raspberry_qr_vault",
            "esp32_qr_vault",
            "esp32_usb_nip46",
            "smartcard",
            "custom_hardware_wallet",
            "external_nip46"
          ]
        },
        "repository": {
          "enum": ["raspberry", "esp32", "smartcard", "hardware"]
        },
        "transport": {
          "enum": ["qr", "usb", "smartcard", "nfc", "nip46_relay", "embedded"]
        },
        "custody": {
          "enum": [
            "stateless_session",
            "device_persistent",
            "card_persistent",
            "custom_hardware_persistent",
            "external_signer"
          ]
        },
        "trusted_review": {
          "enum": ["device_display", "external_review", "external_policy", "display_less"]
        },
        "policy_support": {
          "enum": ["manual_only", "scoped_automation", "external"]
        }
      },
      "additionalProperties": false
    },
    "recovery": { "$ref": "#/$defs/recovery" },
    "capabilities": {
      "type": "object",
      "required": ["methods", "physical_review", "physical_approval", "persistent_grants"],
      "properties": {
        "methods": {
          "type": "array",
          "items": {
            "enum": ["get_capabilities", "get_signing_status", "get_public_key", "sign_event"]
          },
          "uniqueItems": true
        },
        "physical_review": { "type": "boolean" },
        "physical_approval": { "type": "boolean" },
        "persistent_grants": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "policy_profile_id": { "type": "string", "pattern": "^policy-[A-Za-z0-9._:-]{1,121}$" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "signer_route": {
            "properties": { "type": { "const": "raspberry_qr_vault" } },
            "required": ["type"]
          }
        },
        "required": ["signer_route"]
      },
      "then": {
        "properties": {
          "signer_route": {
            "required": ["repository"],
            "properties": {
              "repository": { "const": "raspberry" },
              "transport": { "const": "qr" },
              "custody": { "const": "stateless_session" },
              "trusted_review": { "const": "device_display" },
              "policy_support": { "const": "manual_only" }
            }
          },
          "capabilities": {
            "properties": {
              "physical_review": { "const": true },
              "physical_approval": { "const": true },
              "persistent_grants": { "const": false }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "signer_route": {
            "properties": { "type": { "const": "esp32_qr_vault" } },
            "required": ["type"]
          }
        },
        "required": ["signer_route"]
      },
      "then": {
        "properties": {
          "signer_route": {
            "required": ["repository"],
            "properties": {
              "repository": { "const": "esp32" },
              "transport": { "const": "qr" },
              "custody": { "const": "stateless_session" },
              "trusted_review": { "const": "device_display" },
              "policy_support": { "const": "manual_only" }
            }
          },
          "capabilities": {
            "properties": {
              "physical_review": { "const": true },
              "physical_approval": { "const": true },
              "persistent_grants": { "const": false }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "signer_route": {
            "properties": { "type": { "const": "esp32_usb_nip46" } },
            "required": ["type"]
          }
        },
        "required": ["signer_route"]
      },
      "then": {
        "properties": {
          "signer_route": {
            "required": ["repository"],
            "properties": {
              "repository": { "const": "esp32" },
              "transport": { "const": "usb" },
              "custody": { "const": "device_persistent" },
              "trusted_review": { "const": "device_display" },
              "policy_support": { "const": "scoped_automation" }
            }
          },
          "capabilities": {
            "properties": {
              "physical_review": { "const": true },
              "physical_approval": { "const": true },
              "persistent_grants": { "const": true }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "signer_route": {
            "properties": { "type": { "const": "smartcard" } },
            "required": ["type"]
          }
        },
        "required": ["signer_route"]
      },
      "then": {
        "properties": {
          "signer_route": {
            "required": ["repository"],
            "properties": {
              "repository": { "const": "smartcard" },
              "transport": { "const": "smartcard" },
              "custody": { "const": "card_persistent" },
              "trusted_review": { "const": "display_less" },
              "policy_support": { "const": "manual_only" }
            }
          },
          "capabilities": {
            "properties": {
              "physical_review": { "const": false },
              "physical_approval": { "const": false },
              "persistent_grants": { "const": false }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "signer_route": {
            "properties": { "type": { "const": "custom_hardware_wallet" } },
            "required": ["type"]
          }
        },
        "required": ["signer_route"]
      },
      "then": {
        "properties": {
          "signer_route": {
            "required": ["repository"],
            "properties": {
              "repository": { "const": "hardware" },
              "transport": { "const": "usb" },
              "custody": { "const": "custom_hardware_persistent" },
              "trusted_review": { "const": "device_display" },
              "policy_support": { "const": "scoped_automation" }
            }
          },
          "capabilities": {
            "properties": {
              "physical_review": { "const": true },
              "physical_approval": { "const": true },
              "persistent_grants": { "const": true }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "signer_route": {
            "properties": { "type": { "const": "external_nip46" } },
            "required": ["type"]
          }
        },
        "required": ["signer_route"]
      },
      "then": {
        "properties": {
          "signer_route": {
            "not": { "required": ["repository"] },
            "properties": {
              "transport": { "const": "nip46_relay" },
              "custody": { "const": "external_signer" },
              "trusted_review": { "const": "external_policy" },
              "policy_support": { "const": "external" }
            }
          },
          "capabilities": {
            "properties": {
              "physical_review": { "const": false },
              "physical_approval": { "const": false },
              "persistent_grants": { "const": false }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "recovery": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "path", "account", "source_vector", "source_fingerprint"],
          "properties": {
            "type": { "const": "nip06" },
            "path": { "type": "string", "pattern": "^m/44'/1237'/" },
            "account": { "type": "integer", "minimum": 0 },
            "source_vector": { "type": "string", "minLength": 1 },
            "source_fingerprint": { "type": "string", "pattern": "^[0-9a-f]{16}$" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "slot_id", "backup_required"],
          "properties": {
            "type": { "const": "device_slot" },
            "slot_id": { "type": "string", "minLength": 1 },
            "backup_required": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "card_id", "slot_id", "backup_required"],
          "properties": {
            "type": { "const": "card_slot" },
            "card_id": { "type": "string", "minLength": 1 },
            "slot_id": { "type": "string", "minLength": 1 },
            "backup_required": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "device_id", "slot_id", "backup_required"],
          "properties": {
            "type": { "const": "hardware_wallet_slot" },
            "device_id": { "type": "string", "minLength": 1 },
            "slot_id": { "type": "string", "minLength": 1 },
            "backup_required": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "external_signer_id"],
          "properties": {
            "type": { "const": "external_signer" },
            "external_signer_id": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "additionalProperties": false
}
