{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nsealr.dev/schemas/route-selection-vector-v0.schema.json",
  "title": "nSealr route selection vector v0",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "format", "request", "selection"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]{1,128}$"
    },
    "format": {
      "const": "nsealr-route-selection-vector-v0"
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["account_id", "method"],
      "properties": {
        "account_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]{1,128}$"
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "route_type": {
          "enum": [
            "raspberry_qr_vault",
            "esp32_qr_vault",
            "esp32_usb_nip46",
            "smartcard",
            "custom_hardware_wallet",
            "external_nip46"
          ]
        }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "account_id",
        "public_key",
        "route_type",
        "transport",
        "custody",
        "trusted_review",
        "policy_support",
        "policy_profile_id",
        "physical_review",
        "physical_approval",
        "persistent_grants",
        "contains_secret_material"
      ],
      "properties": {
        "format": {
          "const": "nsealr-route-selection-v0"
        },
        "account_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]{1,128}$"
        },
        "public_key": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "route_type": {
          "enum": [
            "raspberry_qr_vault",
            "esp32_qr_vault",
            "esp32_usb_nip46",
            "smartcard",
            "custom_hardware_wallet",
            "external_nip46"
          ]
        },
        "repository": {
          "enum": ["raspberry", "esp32", "smartcard", "hardware"]
        },
        "transport": {
          "enum": ["qr", "usb", "smartcard", "nfc", "nip46_relay", "embedded"]
        },
        "custody": {
          "enum": [
            "stateless_session",
            "device_persistent",
            "card_persistent",
            "custom_hardware_persistent",
            "external_signer"
          ]
        },
        "trusted_review": {
          "enum": ["device_display", "external_review", "external_policy", "display_less"]
        },
        "policy_support": {
          "enum": ["manual_only", "scoped_automation", "external"]
        },
        "policy_profile_id": {
          "type": "string",
          "pattern": "^policy-[A-Za-z0-9._:-]{1,121}$"
        },
        "physical_review": {
          "type": "boolean"
        },
        "physical_approval": {
          "type": "boolean"
        },
        "persistent_grants": {
          "type": "boolean"
        },
        "contains_secret_material": {
          "const": false
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "route_type": { "const": "raspberry_qr_vault" } },
            "required": ["route_type"]
          },
          "then": {
            "required": ["repository"],
            "properties": {
              "repository": { "const": "raspberry" },
              "transport": { "const": "qr" },
              "custody": { "const": "stateless_session" },
              "trusted_review": { "const": "device_display" },
              "policy_support": { "const": "manual_only" },
              "physical_review": { "const": true },
              "physical_approval": { "const": true },
              "persistent_grants": { "const": false }
            }
          }
        },
        {
          "if": {
            "properties": { "route_type": { "const": "esp32_qr_vault" } },
            "required": ["route_type"]
          },
          "then": {
            "required": ["repository"],
            "properties": {
              "repository": { "const": "esp32" },
              "transport": { "const": "qr" },
              "custody": { "const": "stateless_session" },
              "trusted_review": { "const": "device_display" },
              "policy_support": { "const": "manual_only" },
              "physical_review": { "const": true },
              "physical_approval": { "const": true },
              "persistent_grants": { "const": false }
            }
          }
        },
        {
          "if": {
            "properties": { "route_type": { "const": "esp32_usb_nip46" } },
            "required": ["route_type"]
          },
          "then": {
            "required": ["repository"],
            "properties": {
              "repository": { "const": "esp32" },
              "transport": { "const": "usb" },
              "custody": { "const": "device_persistent" },
              "trusted_review": { "const": "device_display" },
              "policy_support": { "const": "scoped_automation" },
              "physical_review": { "const": true },
              "physical_approval": { "const": true },
              "persistent_grants": { "const": true }
            }
          }
        },
        {
          "if": {
            "properties": { "route_type": { "const": "smartcard" } },
            "required": ["route_type"]
          },
          "then": {
            "required": ["repository"],
            "properties": {
              "repository": { "const": "smartcard" },
              "transport": { "const": "smartcard" },
              "custody": { "const": "card_persistent" },
              "trusted_review": { "const": "display_less" },
              "policy_support": { "const": "manual_only" },
              "physical_review": { "const": false },
              "physical_approval": { "const": false },
              "persistent_grants": { "const": false }
            }
          }
        },
        {
          "if": {
            "properties": { "route_type": { "const": "custom_hardware_wallet" } },
            "required": ["route_type"]
          },
          "then": {
            "required": ["repository"],
            "properties": {
              "repository": { "const": "hardware" },
              "transport": { "const": "usb" },
              "custody": { "const": "custom_hardware_persistent" },
              "trusted_review": { "const": "device_display" },
              "policy_support": { "const": "scoped_automation" },
              "physical_review": { "const": true },
              "physical_approval": { "const": true },
              "persistent_grants": { "const": true }
            }
          }
        },
        {
          "if": {
            "properties": { "route_type": { "const": "external_nip46" } },
            "required": ["route_type"]
          },
          "then": {
            "not": { "required": ["repository"] },
            "properties": {
              "transport": { "const": "nip46_relay" },
              "custody": { "const": "external_signer" },
              "trusted_review": { "const": "external_policy" },
              "policy_support": { "const": "external" },
              "physical_review": { "const": false },
              "physical_approval": { "const": false },
              "persistent_grants": { "const": false }
            }
          }
        }
      ]
    }
  }
}
