{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nsealr.dev/schemas/error-v0.schema.json",
  "title": "nSealr Error Response v0",
  "type": "object",
  "required": ["version", "request_id", "ok", "error"],
  "properties": {
    "version": { "const": 1 },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "ok": { "const": false },
    "error": {
      "type": "object",
      "required": ["code", "message", "retryable"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "unsupported_version",
            "unsupported_method",
            "invalid_request",
            "user_rejected",
            "device_locked",
            "internal_error"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "retryable": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

