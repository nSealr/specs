{
  "format": "nsealr-persistent-secret-custody-contract-v0",
  "name": "persistent-secret-custody-v0",
  "contract_id": "persistent-secret-custody-v0",
  "solution": "custom_hardware_wallet",
  "repository": "hardware",
  "current_status": "research",
  "scope": "Custom persistent-secret hardware-wallet custody gates before production secret storage, PCB claims, or firmware signing enablement.",
  "requirements": {
    "secret_at_rest": {
      "plaintext_allowed": false,
      "allowed_storage": [
        "tropic01_wrapped_secret_blob",
        "esp32_flash_encrypted_blob"
      ],
      "production_storage_enabled": false
    },
    "unlock": {
      "plaintext_locations": [
        "esp32_s3_ram"
      ],
      "required_unlock_assist": [
        "tropic01"
      ],
      "requires_local_unlock": true,
      "requires_device_review_state": true
    },
    "plaintext_persistence": {
      "scope": "unlocked_session_ram_only",
      "forbidden_outputs": [
        "flash",
        "logs",
        "crash_dumps",
        "usb_reports",
        "companion_descriptors",
        "debug_output"
      ]
    },
    "wipe_events": [
      "manual_lock",
      "power_loss",
      "pin_attempt_exhausted",
      "session_timeout",
      "firmware_error",
      "debug_policy_violation"
    ],
    "pin_attempt_policy": {
      "requires_tropic01_mac_and_destroy_or_vendor_equivalent": true,
      "production_required": true
    },
    "backup_export_policy": {
      "enabled_by_default": false,
      "requires_local_device_review": true,
      "requires_physical_approval": true,
      "requires_danger_zone_copy": true
    }
  },
  "non_claims": [
    "This contract does not claim direct TROPIC01 secp256k1 Schnorr/BIP-340 support.",
    "This contract does not enable production signing or production secret storage.",
    "This contract does not apply to stateless QR vault signer families."
  ]
}
